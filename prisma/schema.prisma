// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          Int             @id @default(autoincrement())
  shortname   String          @unique
  title       String
  year        Int
  description String
  isActive    Boolean         @default(true)
  url         String?
  images      Image[]         // Связь с моделью Image
  categories  Category[]      // Связь с рубриками
  tags        ProjectTag[]    // Связь с тегами через промежуточную таблицу
  links       ProjectLink[]   // Связь с ссылками

  @@map("projects")
}

model Image {
  id        Int      @id @default(autoincrement())
  url       String   // URL изображения
  alt       String?  // Альтернативный текст
  order     Int      @default(0) // Порядок отображения
  projectId Int      // Внешний ключ
  project   Project  @relation(fields: [projectId], references: [id]) // Связь с проектом

  @@map("images")
}

// Модель для рубрик (дизайн, разработка ПО, менеджмент)
model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  projects    Project[] // Связь с проектами

  @@map("categories")
}

// Модель для тегов (стек технологий)
model Tag {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  projects    ProjectTag[] // Связь с проектами через промежуточную таблицу

  @@map("tags")
}

// Промежуточная таблица для связи многие-ко-многим между Project и Tag
model ProjectTag {
  id        Int     @id @default(autoincrement())
  projectId Int
  tagId     Int
  project   Project @relation(fields: [projectId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@unique([projectId, tagId])
  @@map("project_tags")
}

// Ссылки проекта
model ProjectLink {
  id        Int     @id @default(autoincrement())
  name      String
  href      String
  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  @@map("links")
}

// Контакты сайта (email, telegram, телефон и т.д.)
model Contact {
  id    Int    @id @default(autoincrement())
  kind  String // email, phone, telegram, link
  label String
  value String
  order Int    @default(0)

  @@map("contacts")
}